# ── Elasticsearch ──────────────────────────────────────────────
ES_HOST=http://localhost:9200
ES_USERNAME=elastic
ES_PASSWORD=mars_hackathon

# Kibana password (used during setup only)
KIBANA_PASSWORD=mars_kibana

# ── LLM Keys ───────────────────────────────────────────────────
# Planner + Reviewer agents use the smarter model
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Which provider to use: "anthropic" | "openai"
LLM_PROVIDER=anthropic

# Model names
ANTHROPIC_REASONING_MODEL=claude-opus-4-6        # Planner, Reviewer
ANTHROPIC_FAST_MODEL=claude-haiku-4-5-20251001   # Retrieval agents
OPENAI_REASONING_MODEL=gpt-4o
OPENAI_FAST_MODEL=gpt-4o-mini

# ── MARS Settings ──────────────────────────────────────────────
# Confidence threshold below which follow-up queries are triggered
FOLLOWUP_CONFIDENCE_THRESHOLD=0.6
# Max follow-up iterations per claim
FOLLOWUP_MAX_ITERATIONS=3
# How many claims must be corroborated by 2+ sources
CRITICAL_CLAIM_MIN_SOURCES=2
